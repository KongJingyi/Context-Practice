# 复制本文件为 .env 并填入真实值（.env 已被 git 忽略，勿提交）
# 在 ContextPractice-backend 目录下执行: copy .env.example .env

# DeepSeek（默认，与 application-dev.yml 中 app.ai 配置对应）
DEEPSEEK_API_KEY=sk-你的密钥

# 腾讯云 TRTC（实时音视频 + 云录制）
TRTC_SDK_APP_ID=1600146515
TRTC_SECRET_KEY=
# CAM API 密钥（云录制 CreateCloudRecording 用，在 https://console.cloud.tencent.com/cam/capi 创建）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TRTC_CLOUD_REGION=ap-guangzhou
# 存储：vod（云点播，默认）或 cos
TRTC_RECORDING_STORAGE=vod
TRTC_VOD_SUB_APP_ID=0
TRTC_COS_BUCKET=
TRTC_COS_REGION=ap-guangzhou
TRTC_COS_PATH_PREFIX=context-practice/recordings
# TRTC 控制台 → 应用 → 回调配置 → 录制回调密钥
TRTC_RECORDING_CALLBACK_SECRET=
# 录制回调 URL 填在 TRTC 控制台（非后端代码），须公网可访问，例如：
# https://<你的域名或 ngrok>/api/v1/trtc/recording-callback
# 未配置云 API 时的演示回放 MP4
TRTC_DEV_RECORDING_URL=https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4

# 阿里云短信认证（PNVS / dypnsapi，application-dev.yml 中 sms-provider: aliyun）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_CODE=100001

# 若改用 Kimi，可取消注释并修改 application-dev.yml 中的 base-url / model
# MOONSHOT_API_KEY=sk-你的密钥
